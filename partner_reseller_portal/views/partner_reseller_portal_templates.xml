<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_reseller_portal" name="Reseller Portal">
        <t t-call="portal.portal_layout">
            <div class="o_partner_reseller_portal_page py-4">
                <div class="container">
                    <div class="mb-4">
                        <span class="text-uppercase text-muted small fw-semibold">Partner Portal</span>
                        <h1 class="h2 mt-2 mb-2">Reseller Portal</h1>
                        <p class="text-muted mb-0">
                            Review reseller-scoped opportunities, quotations, sales orders, invoices, and customers.
                        </p>
                    </div>
                    <owl-component
                        name="partner_reseller_portal.PartnerPortalRoot"
                        t-att-props="component_props_json"
                    />
                </div>
            </div>
        </t>
    </template>
</odoo>
