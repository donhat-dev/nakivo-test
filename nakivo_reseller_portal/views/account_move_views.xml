<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- account.move form extension: adds reseller_partner_id in the Invoice group
         of the Other Info tab (customer invoices and credit notes only). -->
    <record id="view_account_move_form_reseller" model="ir.ui.view">
        <field name="name">account.move.form.reseller</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <group name="sale_info_group" position="inside">
                <field
                    name="reseller_partner_id"
                    options="{'no_create': True}"
                    invisible="move_type not in ('out_invoice', 'out_refund')"
                    groups="base.group_user"
                />
            </group>
        </field>
    </record>
</odoo>
