<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="web_login_reseller_portal_cta" inherit_id="web.login_oauth" name="Web Login Reseller Portal CTA">
        <xpath expr="//t[@t-set='auth_btns']" position="after">
            <t t-set="portal_btn_label">Login to Reseller Portal</t>
            <t t-set="portal_btn"
               t-value="[] if request.params.get('reseller_portal_login') else [{'css_class': 'fa fa-th-large', 'body': portal_btn_label, 'auth_link': '/my/reseller-portal/login', 'list_item_class': 'reseller_portal_login_link'}]"
            />
            <t t-set="auth_btns" t-value="auth_btns + portal_btn"/>
        </xpath>
    </template>

    <template id="portal_frontend_layout_inter_font" inherit_id="portal.frontend_layout" name="Portal Inter Font">
        <xpath expr="//head" position="inside">
            <link rel="preconnect" href="https://fonts.googleapis.com/"/>
            <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin=""/>
            <link
                href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap"
                rel="stylesheet"
            />
        </xpath>
    </template>

    <!-- Portal home tile (Gap 1) -->
    <template
        id="portal_my_home_reseller"
        name="Reseller Dashboard"
        inherit_id="portal.portal_my_home"
        customize_show="True"
        priority="30"
    >
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_client_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/nakivo_reseller_portal/static/src/img/icon.svg'"/>
                <t t-set="title">Reseller Dashboard</t>
                <t t-set="url" t-value="'/my/reseller-portal'"/>
                <t t-set="text">View your opportunities, orders, invoices, more</t>
                <t t-set="placeholder_count" t-value="'reseller_portal_count'"/>
                <t t-set="config_card" t-value="True"/>
            </t>
        </div>
    </template>

    <!-- Breadcrumb extension for the main SPA page -->
    <template id="portal_breadcrumbs_reseller" inherit_id="portal.portal_breadcrumbs" name="Reseller Portal Breadcrumbs">
        <xpath expr="//ol[hasclass('breadcrumb')]" position="inside">
            <li t-if="page_name == 'nakivo_reseller_portal'" class="breadcrumb-item active">Reseller Portal</li>
        </xpath>
    </template>

    <!-- Main Owl SPA page -->
    <template id="portal_my_reseller_portal" name="Reseller Portal">
        <t t-call="portal.portal_layout">
            <t t-set="no_breadcrumbs" t-value="True"/>
            <owl-component
                name="nakivo_reseller_portal.PartnerPortalRoot"
                t-att-props="component_props_json"
            />
        </t>
    </template>

    <!-- QWeb list pages (Gap 2) -->
    <template id="portal_reseller_opportunities" name="Reseller Opportunities">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>
            <nav aria-label="breadcrumb" class="o_portal_submenu">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="/my/reseller-portal">Reseller Portal</a>
                    </li>
                    <li class="breadcrumb-item active">Opportunities</li>
                </ol>
            </nav>
            <div class="o_portal_my_doc_table table-responsive">
                <t t-if="not opportunities">
                    <div class="alert alert-info">No opportunities found.</div>
                </t>
                <t t-else="">
                    <table class="table table-hover o_portal_my_doc_table mb-0">
                        <thead>
                            <tr>
                                <th>Reference</th>
                                <th>Name</th>
                                <th>Customer</th>
                                <th>Stage</th>
                                <th>Expected Revenue</th>
                                <th>Deadline</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="opportunities" t-as="opp">
                                <tr>
                                    <td><t t-esc="opp.id"/></td>
                                    <td><t t-esc="opp.name"/></td>
                                    <td><t t-esc="opp.partner_id.display_name or ''"/></td>
                                    <td><t t-esc="opp.stage_id.name or ''"/></td>
                                    <td><t t-esc="opp.expected_revenue"/></td>
                                    <td><t t-esc="opp.date_deadline or ''"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
            </div>
        </t>
    </template>

    <template id="portal_reseller_orders" name="Reseller Orders">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>
            <nav aria-label="breadcrumb" class="o_portal_submenu">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="/my/reseller-portal">Reseller Portal</a>
                    </li>
                    <li class="breadcrumb-item active">Orders</li>
                </ol>
            </nav>
            <div class="o_portal_my_doc_table table-responsive">
                <t t-if="quotations">
                    <h5 class="mt-3">Quotations</h5>
                    <table class="table table-hover o_portal_my_doc_table mb-0">
                        <thead>
                            <tr>
                                <th>Reference</th>
                                <th>Customer</th>
                                <th>Order Date</th>
                                <th>Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="quotations" t-as="order">
                                <tr>
                                    <td><t t-esc="order.name"/></td>
                                    <td><t t-esc="order.partner_id.display_name or ''"/></td>
                                    <td><t t-esc="order.date_order"/></td>
                                    <td><t t-esc="order.amount_total"/> <t t-esc="order.currency_id.name"/></td>
                                    <td><t t-esc="order.state"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
                <t t-if="sales_orders">
                    <h5 class="mt-3">Sales Orders</h5>
                    <table class="table table-hover o_portal_my_doc_table mb-0">
                        <thead>
                            <tr>
                                <th>Reference</th>
                                <th>Customer</th>
                                <th>Order Date</th>
                                <th>Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="sales_orders" t-as="order">
                                <tr>
                                    <td><t t-esc="order.name"/></td>
                                    <td><t t-esc="order.partner_id.display_name or ''"/></td>
                                    <td><t t-esc="order.date_order"/></td>
                                    <td><t t-esc="order.amount_total"/> <t t-esc="order.currency_id.name"/></td>
                                    <td><t t-esc="order.state"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
                <t t-if="not quotations and not sales_orders">
                    <div class="alert alert-info">No orders found.</div>
                </t>
            </div>
        </t>
    </template>

    <template id="portal_reseller_invoices" name="Reseller Invoices">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>
            <nav aria-label="breadcrumb" class="o_portal_submenu">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="/my/reseller-portal">Reseller Portal</a>
                    </li>
                    <li class="breadcrumb-item active">Invoices</li>
                </ol>
            </nav>
            <div class="o_portal_my_doc_table table-responsive">
                <t t-if="not invoices">
                    <div class="alert alert-info">No invoices found.</div>
                </t>
                <t t-else="">
                    <table class="table table-hover o_portal_my_doc_table mb-0">
                        <thead>
                            <tr>
                                <th>Reference</th>
                                <th>Customer</th>
                                <th>Invoice Date</th>
                                <th>Amount</th>
                                <th>Payment State</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="invoices" t-as="inv">
                                <tr>
                                    <td><t t-esc="inv.name"/></td>
                                    <td><t t-esc="inv.partner_id.display_name or ''"/></td>
                                    <td><t t-esc="inv.invoice_date or ''"/></td>
                                    <td><t t-esc="inv.amount_total"/> <t t-esc="inv.currency_id.name"/></td>
                                    <td><t t-esc="inv.payment_state"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
            </div>
        </t>
    </template>

    <template id="portal_reseller_customers" name="Reseller Customers">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="False"/>
            <nav aria-label="breadcrumb" class="o_portal_submenu">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="/my/reseller-portal">Reseller Portal</a>
                    </li>
                    <li class="breadcrumb-item active">Customers</li>
                </ol>
            </nav>
            <div class="o_portal_my_doc_table table-responsive">
                <t t-if="not customers">
                    <div class="alert alert-info">No customers found.</div>
                </t>
                <t t-else="">
                    <table class="table table-hover o_portal_my_doc_table mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>City</th>
                                <th>Country</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="customers" t-as="cust">
                                <tr>
                                    <td><t t-esc="cust.display_name"/></td>
                                    <td><t t-esc="cust.email or ''"/></td>
                                    <td><t t-esc="cust.phone or cust.mobile or ''"/></td>
                                    <td><t t-esc="cust.city or ''"/></td>
                                    <td><t t-esc="cust.country_id.name or ''"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
            </div>
        </t>
    </template>
</odoo>
