<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- sale.order form extension: adds reseller_partner_id in the Tracking group -->
    <record id="view_sale_order_form_reseller" model="ir.ui.view">
        <field name="name">sale.order.form.reseller</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <group name="sale_reporting" position="inside">
                <field
                    name="reseller_partner_id"
                    options="{'no_create': True}"
                    groups="base.group_user"
                />
            </group>
        </field>
    </record>
</odoo>
