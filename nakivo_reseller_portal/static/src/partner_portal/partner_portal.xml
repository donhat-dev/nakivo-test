<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="nakivo_reseller_portal.PartnerPortalRoot">
        <div class="o_nakivo_reseller_portal d-lg-flex min-vh-100">

            <AppSidebar
                sections="sidebarSections"
                activeSection="state.activeSection"
                userName="props.userName"
                onNavigate.bind="onNavigate"
            />

            <main class="flex-grow-1 min-w-0 p-3 p-lg-4 overflow-auto">
                <!-- Global error alert -->
                <div t-if="state.error" class="alert alert-danger small py-2 px-3 mb-4">
                    <t t-esc="state.error"/>
                </div>

                <!-- Dashboard view -->
                <t t-if="state.activeSection === 'dashboard'">
                    <DashboardView
                        cards="dashboardCards"
                        stats="dashboardStats"
                        onNavigate.bind="onNavigate"
                        loading="state.loading"
                        lastUpdated="state.lastUpdated"
                        onRefresh.bind="onRefreshDashboard"
                    />
                </t>

                <!-- Section list view -->
                <t t-elif="currentSectionConfig">
                    <RecordListView
                        title="currentSectionConfig.title"
                        subtitle="currentSectionConfig.subtitle or ''"
                        columns="currentSectionConfig.columns"
                        records="currentRecords"
                        loading="state.loading"
                        showCreateButton="currentSectionConfig.showCreateButton"
                        onCreateClick.bind="onCreateClick"
                        deleteAction="deleteAction"
                    />
                </t>

                <!-- Create opportunity modal (portal-level, renders over sidebar too) -->
                <t t-if="state.showCreateModal">
                    <CreateOpportunityModal
                        customers="state.dashboard.customers"
                        apiBasePath="props.apiBasePath"
                        csrfToken="props.csrfToken"
                        onClose.bind="onModalClose"
                        onCreated.bind="onOpportunityCreated"
                    />
                </t>
            </main>

        </div>
    </t>
</templates>
