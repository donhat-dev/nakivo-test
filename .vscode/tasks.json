{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker: Restart Odoo",
      "type": "shell",
      "command": "docker compose -f docker/docker-compose.yml restart odoo",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Restart Odoo (Debug)",
      "type": "shell",
      "command": "docker compose -f docker/docker-compose.yml -f docker/docker-compose.debug.yml restart odoo",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
